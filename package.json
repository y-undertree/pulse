{
  "name": "pulse-shared-state",
  "version": "0.1.0",
  "private": true,
  "description": "A lightweight SQLite shared state CLI for coordinating AI coding agents.",
  "type": "module",
  "bin": {
    "pulse": "build/src/bin.js"
  },
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('build', { recursive: true, force: true })\"",
    "coverage": "node --disable-warning=ExperimentalWarning --import tsx --test --experimental-test-coverage --test-coverage-lines=100 --test-coverage-functions=100 --test-coverage-branches=100 '--test-coverage-include=src/**/*.ts' --test-coverage-exclude=src/bin.ts 'tests/**/*.test.ts'",
    "dev": "node --disable-warning=ExperimentalWarning --import tsx src/bin.ts",
    "test": "node --disable-warning=ExperimentalWarning --import tsx --test 'tests/**/*.test.ts'",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "verify": "npm run typecheck && npm run coverage && npm run build"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
